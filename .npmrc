# Expo + React Native need a flat node_modules to resolve native modules reliably.
# `hoisted` makes pnpm behave like npm/yarn-classic, which is the supported layout for Expo monorepos.
node-linker=hoisted
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*metro*
public-hoist-pattern[]=@react-native*
public-hoist-pattern[]=*nativewind*
