node_modules/
dist/
.expo/
.expo-shared/
# Prebuild-generated native projects (NOT the local Expo modules' android/ sources)
apps/mobile/android/
apps/mobile/ios/
*.log
.DS_Store
coverage/
*.tsbuildinfo
.env*.local
web-build/

# Graphify knowledge graph (https://github.com/rhanka/graphify)
# Commit only the portable, repo-relative artifacts; ignore all local lifecycle
# state (branch.json/worktree.json/needs_update/cache/, manifest.json, etc. -
# these may contain absolute paths and must never be committed).
.graphify/*
!.graphify/graph.json
!.graphify/GRAPH_REPORT.md
!.graphify/graph.html
!.graphify/flows.json
!.graphify/wiki/

# Release signing - NEVER commit; back up keystore + passwords out-of-band
apps/mobile/credentials/
*.keystore
*.jks

# Device screenshots - may contain private chat content, never commit
docs/screenshots/

# Local Expo module build output
apps/mobile/modules/**/android/build/
